        "/^cat > icons/generate\\.html << 'ICON_EOF'\n<!-- Open in browser, right-click canvas, save as PNG for each size -->\n<canvas id=\"c16\" width=\"16\" height=\"16\"></canvas>\n<canvas id=\"c48\" width=\"48\" height=\"48\"></canvas>\n<canvas id=\"c128\" width=\"128\" height=\"128\"></canvas>\n<script>\nfunction draw\\(id, size\\) \\{\n  const c = document\\.getElementById\\(id\\)\\.getContext\\('2d'\\);\n  // Background\n  c\\.fillStyle = '#1a1a2e';\n  c\\.fillRect\\(0, 0, size, size\\);\n  // Lightning bolt\n  c\\.fillStyle = '#e94560';\n  c\\.font = `bold \\$\\{size \\* 0\\.7\\}px sans-serif`;\n  c\\.textAlign = 'center';\n  c\\.textBaseline = 'middle';\n  c\\.fillText\\('⚡', size/2, size/2\\);\n\\}\ndraw\\('c16', 16\\); draw\\('c48', 48\\); draw\\('c128', 128\\);\n</script>\nICON_EOF\necho \"Created icon generator HTML\\. For now, creating 1x1 placeholder PNGs\\.\\.\\.\"\n\n# Create minimal valid PNG files as placeholders \\(1x1 transparent\\)\n# These are the smallest valid PNGs possible\npython3 -c \"\nimport struct, zlib\n\ndef make_png\\(size\\):\n    # IHDR\n    ihdr_data = struct\\.pack\\('>IIBBBBB', size, size, 8, 2, 0, 0, 0\\)\n    ihdr = b'IHDR' \\+ ihdr_data\n    ihdr_crc = struct\\.pack\\('>I', zlib\\.crc32\\(ihdr\\) & 0xffffffff\\)\n    ihdr_chunk = struct\\.pack\\('>I', len\\(ihdr_data\\)\\) \\+ ihdr \\+ ihdr_crc\n\n    # IDAT - simple red square\n    raw = b''\n    for y in range\\(size\\):\n        raw \\+= b'\\\\x00'  # filter none\n        for x in range\\(size\\):\n            raw \\+= b'\\\\xe9\\\\x45\\\\x60'  # #e94560\n\n    compressed = zlib\\.compress\\(raw\\)\n    idat = b'IDAT' \\+ compressed\n    idat_crc = struct\\.pack\\('>I', zlib\\.crc32\\(idat\\) & 0xffffffff\\)\n    idat_chunk = struct\\.pack\\('>I', len\\(compressed\\)\\) \\+ idat \\+ idat_crc\n\n    # IEND\n    iend = b'IEND'\n    iend_crc = struct\\.pack\\('>I', zlib\\.crc32\\(iend\\) & 0xffffffff\\)\n    iend_chunk = struct\\.pack\\('>I', 0\\) \\+ iend \\+ iend_crc\n\n    return b'\\\\x89PNG\\\\r\\\\n\\\\x1a\\\\n' \\+ ihdr_chunk \\+ idat_chunk \\+ iend_chunk\n\nfor size, name in \\[\\(16, 'icons/icon16\\.png'\\), \\(48, 'icons/icon48\\.png'\\), \\(128, 'icons/icon128\\.png'\\)\\]:\n    with open\\(name, 'wb'\\) as f:\n        f\\.write\\(make_png\\(size\\)\\)\n    print\\(f'Created \\{name\\} \\(\\{size\\}x\\{size\\}\\)'\\)\n\"$/": {
