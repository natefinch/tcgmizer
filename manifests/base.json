{
  "manifest_version": 3,
  "name": "TCGmizer",
  "version": "1.1.2",
  "description": "Optimizes your TCGPlayer cart to minimize total cost including shipping, using integer linear programming.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "host_permissions": [
    "https://www.tcgplayer.com/*",
    "https://mp-search-api.tcgplayer.com/*",
    "https://mpapi.tcgplayer.com/*",
    "https://mpgateway.tcgplayer.com/*",
    "https://tcgplayer.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.tcgplayer.com/cart*",
        "https://tcgplayer.com/cart*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "results-ui.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/tcgm-16.png",
      "32": "icons/tcgm-32.png",
      "48": "icons/tcgm-48.png",
      "128": "icons/tcgm-128.png"
    }
  },
  "icons": {
    "16": "icons/tcgm-16.png",
    "32": "icons/tcgm-32.png",
    "48": "icons/tcgm-48.png",
    "128": "icons/tcgm-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "highs.wasm"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
